# PostgreSQL (matches docker-compose defaults)
POSTGRES_USER=anime
POSTGRES_PASSWORD=anime
POSTGRES_DB=anime_triage
DATABASE_URL=postgresql+asyncpg://anime:anime@localhost:5432/anime_triage

# OpenAI
OPENAI_API_KEY=sk-...

# AniList (no auth required for public queries)
ANILIST_API_URL=https://graphql.anilist.co

# Logfire observability (https://logfire.pydantic.dev)
LOGFIRE_TOKEN=

# Next.js — server-side only (never exposed to the browser)
API_URL=http://localhost:8000
